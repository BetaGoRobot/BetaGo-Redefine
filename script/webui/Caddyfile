# BetaGo WebUI Caddy 配置（纯内网部署）。
# 监听 80，托管 SPA 静态文件，把 /api/* 反代到主后端。
#
# 多 bot 场景下，浏览器假定与各 bot 在同一内网，直接通过
# BotInstance.baseURL 连各自的内网地址，webui 这层不再做 /bot/<id>/api/*
# 同源反代。如果以后需要支持外网浏览器，再单独引入一份反代片段。
:80 {
	root * /usr/share/caddy

	# 主后端：浏览器走同源 /api。
	handle /api/* {
		reverse_proxy {$BACKEND_URL}
	}

	# /config.js 由 entrypoint 在容器启动时渲染，关掉缓存确保改 env 重启即生效。
	@configjs path /config.js
	handle @configjs {
		header Cache-Control "no-store, must-revalidate"
		header Pragma "no-cache"
		file_server
	}

	# 其余请求走静态文件，未命中回退到 index.html（SPA 路由）。
	handle {
		try_files {path} /index.html
		file_server
	}
}

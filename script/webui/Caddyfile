# BetaGo WebUI Caddy 配置（容器内反代版）。
# 监听 80，托管 SPA 静态文件，并在容器内承担所有跨域 / 跨网段反代：
#
#   - /api/*          → BACKEND_URL 默认后端（运维兜底入口；探活和单后端老路径）
#   - /bot/<id>/api/* → 各 bot 的内网 baseURL（由 entrypoint 从 VITE_BOTS 渲染）
#
# 这样浏览器只跟 webui 容器同域通信，运维只需要在 VITE_BOTS 中填**内网地址**，
# 多 bot 路由也跟 env 同步刷新，无需手维护 Caddyfile。

:80 {
	root * /usr/share/caddy

	# 各 bot 后端反代：由 docker-entrypoint.sh 从 VITE_BOTS 渲染到 bots.caddy。
	# 文件不存在时 Caddy 直接跳过（不会启动失败）。
	import bots.caddy

	# 主后端：浏览器走同源 /api，作为单 bot 部署/调试的兜底入口。
	handle /api/* {
		reverse_proxy {$BACKEND_URL}
	}

	# /config.js 由 entrypoint 在容器启动时渲染，关掉缓存确保改 env 重启即生效。
	@configjs path /config.js
	handle @configjs {
		header Cache-Control "no-store, must-revalidate"
		header Pragma "no-cache"
		file_server
	}

	# 其余请求走静态文件，未命中回退到 index.html（SPA 路由）。
	handle {
		try_files {path} /index.html
		file_server
	}
}

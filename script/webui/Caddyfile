# BetaGo WebUI Caddy 配置。
# 监听 80，托管 SPA 静态文件，把 /api/* 反代到后端（BACKEND_URL 运行时注入）。
:80 {
	root * /usr/share/caddy

	# /api 反向代理到后端 WebUI 服务，避免浏览器跨域。
	handle /api/* {
		reverse_proxy {$BACKEND_URL}
	}

	# /config.js 由 entrypoint 在容器启动时根据环境变量渲染到该路径，
	# 关掉浏览器缓存以确保改了 env 重启容器即生效。
	@configjs path /config.js
	handle @configjs {
		header Cache-Control "no-store, must-revalidate"
		header Pragma "no-cache"
		file_server
	}

	# 其余请求走静态文件，未命中回退到 index.html（SPA 路由）。
	handle {
		try_files {path} /index.html
		file_server
	}
}

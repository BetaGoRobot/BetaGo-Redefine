# docker compose 部署参数。复制为 .env 后按需修改。

# 镜像 tag（CI 推送的镜像）
LARKBOT_IMAGE=kevinmatt/larkbot_v2:latest
WEBUI_IMAGE=kevinmatt/betago_webui:latest

# 宿主暴露端口
WEBUI_PORT=8080          # 仅当取消 webui.ports 注释、需要本地直连时使用
WEBUI_BACKEND_PORT=8090  # 后端 WebUI API 端口 -> larkrobot 容器 8090

# Traefik 反代（前面已有 Traefik，docker provider + labels）
WEBUI_HOST=webui.example.com   # WebUI 对外域名
TRAEFIK_CERTRESOLVER=le        # Traefik 里配置的 ACME certresolver 名

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=betago
